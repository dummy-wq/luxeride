# MongoDB Configuration (Production should use Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/luxeride?retryWrites=true&w=majority
MONGODB_DB=luxeride
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password

# JWT secret key for secure authentication signing
JWT_SECRET=super-secret-key-change-this-for-production-security

# Admin Credentials (Initial Setup - Change these!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

# Node Environment (development | production)
NODE_ENV=development
